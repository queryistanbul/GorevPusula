# Environment Configuration Template
# Copy this file and adjust values for your environment

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=task_management
DB_USER=root
DB_PASSWORD=your_mysql_password_here

# JWT Configuration
# IMPORTANT: Change this secret key in production!
JWT_SECRET=your-very-secret-key-change-this-in-production-min-32-chars
JWT_EXPIRE=24h

# CORS Configuration
# Update this to match your frontend URL
CORS_ALLOW_ORIGIN=http://localhost:3000

# Application Environment
APP_ENV=development

# File Upload (optional, defaults in config.php will be used)
# UPLOAD_DIR=/path/to/uploads
# MAX_FILE_SIZE=10485760
